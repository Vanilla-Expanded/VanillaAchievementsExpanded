<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<AchievementsExpanded.AchievementDef>
		<defName>VAE_GravshipLandings</defName>
		<label>Gravship landing</label>
		<description>Land a gravship</description>
		<tab>VAE_DLCTab</tab>
		<tracker Class="AchievementsExpanded.GravshipLandingTracker">
			<count>1</count>
		</tracker>
		<texPath>Achievements/VAE_WarAgainstTheMachines</texPath>
		<points>10</points>
	</AchievementsExpanded.AchievementDef>
	
	<AchievementsExpanded.AchievementDef>
		<defName>VAE_EnterTwoMaps</defName>
		<label>Enter two maps</label>
		<description>Enter two maps</description>
		<tab>VAE_DLCTab</tab>
		<tracker Class="AchievementsExpanded.MapEnteringTracker">
			<simpleMapVisitCount>2</simpleMapVisitCount>
		</tracker>
		<texPath>Achievements/VAE_WarAgainstTheMachines</texPath>
		<points>10</points>
	</AchievementsExpanded.AchievementDef>
	
	<AchievementsExpanded.AchievementDef>
		<defName>VAE_VisitDeserts</defName>
		<label>Visit a desert and an extreme desert</label>
		<description>Visit a desert and an extreme desert</description>
		<tab>VAE_DLCTab</tab>
		<tracker Class="AchievementsExpanded.MapEnteringTracker">
			<biomesToVisit><li>Desert</li><li>ExtremeDesert</li></biomesToVisit>
		</tracker>
		<texPath>Achievements/VAE_WarAgainstTheMachines</texPath>
		<points>10</points>
	</AchievementsExpanded.AchievementDef>
	<AchievementsExpanded.AchievementDef>
		<defName>VAE_VisitMutators</defName>
		<label>Visit rivers</label>
		<description>Visit river delta and lake</description>
		<tab>VAE_DLCTab</tab>
		<tracker Class="AchievementsExpanded.MapEnteringTracker">
			<mutatorsToVisit><li>RiverDelta</li><li>Lake</li></mutatorsToVisit>
		</tracker>
		<texPath>Achievements/VAE_WarAgainstTheMachines</texPath>
		<points>10</points>
	</AchievementsExpanded.AchievementDef>
	<AchievementsExpanded.AchievementDef>
		<defName>VAE_VisitLandmark</defName>
		<label>Visit landmark</label>
		<description>Visit DryLake</description>
		<tab>VAE_DLCTab</tab>
		<tracker Class="AchievementsExpanded.MapEnteringTracker">
			<landmarksToVisit><li>DryLake</li></landmarksToVisit>
		</tracker>
		<texPath>Achievements/VAE_WarAgainstTheMachines</texPath>
		<points>10</points>
	</AchievementsExpanded.AchievementDef>
	
</Defs>
